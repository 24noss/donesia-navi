---
interface Props {
  restaurants: string;
  height?: string;
}

const { restaurants, height = '520px' } = Astro.props;
const GMAP_KEY = 'AIzaSyCU3hYfihH03MjQAxVSHjh49JCK2tOMzdQ';
---

<div class="restaurant-map-wrap">
  <div class="map-cuisine-filters" id="map-cuisine-filters"></div>
  <div id="restaurant-map" style={`height:${height};width:100%;border-radius:var(--radius-lg);border:1px solid var(--border);background:#e8e6e1;`}></div>
</div>

<script is:inline define:vars={{ restaurants, GMAP_KEY }}>
(function() {
  var data = JSON.parse(restaurants);

  var cuisineConfig = {
    japanese:   { label: '日本食',           color: '#1B2D4F', icon: '🍣' },
    korean:     { label: '韓国料理',         color: '#CE3B3B', icon: '🍖' },
    chinese:    { label: '中華料理',         color: '#D97706', icon: '🥟' },
    indonesian: { label: 'インドネシア料理', color: '#C9A44A', icon: '🌶️' },
    european:   { label: '西洋料理',         color: '#3A6B8C', icon: '🍷' },
    cafe:       { label: 'カフェ',           color: '#64748B', icon: '☕' },
    other:      { label: 'その他',           color: '#7A8A9E', icon: '🍽️' },
  };

  var priceLabels = { budget: '¥', mid: '¥¥', high: '¥¥¥', luxury: '¥¥¥¥' };

  // Count cuisines
  var cuisineCounts = {};
  data.forEach(function(r) {
    cuisineCounts[r.cuisine] = (cuisineCounts[r.cuisine] || 0) + 1;
  });

  // Render filter buttons
  var filtersEl = document.getElementById('map-cuisine-filters');
  if (filtersEl) {
    var allBtn = document.createElement('button');
    allBtn.className = 'map-filter-btn active';
    allBtn.dataset.cuisine = 'all';
    allBtn.textContent = 'すべて (' + data.length + ')';
    filtersEl.appendChild(allBtn);

    Object.keys(cuisineConfig).forEach(function(key) {
      if (!cuisineCounts[key]) return;
      var btn = document.createElement('button');
      btn.className = 'map-filter-btn';
      btn.dataset.cuisine = key;
      btn.innerHTML = cuisineConfig[key].icon + ' ' + cuisineConfig[key].label + ' (' + cuisineCounts[key] + ')';
      btn.style.setProperty('--filter-color', cuisineConfig[key].color);
      filtersEl.appendChild(btn);
    });
  }

  // Load Google Maps
  function loadGoogleMaps(cb) {
    if (window.google && window.google.maps) { cb(); return; }
    window._gmapCallback = cb;
    var s = document.createElement('script');
    s.src = 'https://maps.googleapis.com/maps/api/js?key=' + GMAP_KEY + '&callback=_gmapCallback&v=weekly&language=ja';
    s.async = true;
    s.defer = true;
    document.head.appendChild(s);
  }

  function initWhenVisible() {
    var mapEl = document.getElementById('restaurant-map');
    if (!mapEl) return;

    if (mapEl.offsetParent !== null && mapEl.offsetWidth > 0) {
      loadGoogleMaps(initMap);
      return;
    }

    // Observe for tab switching
    var obs = new MutationObserver(function() {
      if (mapEl.offsetParent !== null && mapEl.offsetWidth > 0) {
        obs.disconnect();
        loadGoogleMaps(initMap);
      }
    });
    obs.observe(document.body, { attributes: true, childList: true, subtree: true });

    setTimeout(function() {
      if (mapEl.offsetParent !== null && mapEl.offsetWidth > 0) {
        obs.disconnect();
        loadGoogleMaps(initMap);
      }
    }, 1000);
  }

  var mapInstance = null;
  var allMarkers = [];

  function initMap() {
    if (mapInstance) return;

    var mapEl = document.getElementById('restaurant-map');
    if (!mapEl || !window.google) return;

    var isDark = document.documentElement.getAttribute('data-theme') === 'dark';

    var darkStyle = [
      { elementType: 'geometry', stylers: [{ color: '#1d2c4d' }] },
      { elementType: 'labels.text.fill', stylers: [{ color: '#8ec3b9' }] },
      { elementType: 'labels.text.stroke', stylers: [{ color: '#1a3646' }] },
      { featureType: 'road', elementType: 'geometry', stylers: [{ color: '#304a7d' }] },
      { featureType: 'road', elementType: 'labels.text.fill', stylers: [{ color: '#98a5be' }] },
      { featureType: 'water', elementType: 'geometry', stylers: [{ color: '#0e1626' }] },
      { featureType: 'poi', elementType: 'geometry', stylers: [{ color: '#283d6a' }] },
      { featureType: 'transit', elementType: 'geometry', stylers: [{ color: '#2f3948' }] },
    ];

    var map = new google.maps.Map(mapEl, {
      center: { lat: -6.2088, lng: 106.8456 },
      zoom: 12,
      styles: isDark ? darkStyle : [],
      mapTypeControl: false,
      streetViewControl: false,
      fullscreenControl: true,
      zoomControlOptions: { position: google.maps.ControlPosition.RIGHT_BOTTOM },
    });
    mapInstance = map;

    // Theme change observer
    new MutationObserver(function(mutations) {
      mutations.forEach(function(m) {
        if (m.attributeName === 'data-theme') {
          var dark = document.documentElement.getAttribute('data-theme') === 'dark';
          map.setOptions({ styles: dark ? darkStyle : [] });
        }
      });
    }).observe(document.documentElement, { attributes: true });

    // Create markers
    var bounds = new google.maps.LatLngBounds();
    var infoWindow = new google.maps.InfoWindow();

    data.forEach(function(r) {
      if (!r.lat || !r.lng) return;
      var cc = cuisineConfig[r.cuisine] || cuisineConfig.other;

      var marker = new google.maps.Marker({
        position: { lat: r.lat, lng: r.lng },
        map: map,
        title: r.name,
        icon: {
          path: google.maps.SymbolPath.CIRCLE,
          scale: 12,
          fillColor: cc.color,
          fillOpacity: 0.9,
          strokeColor: '#ffffff',
          strokeWeight: 2.5,
        },
        label: {
          text: cc.icon,
          fontSize: '14px',
        },
      });

      var gmapsUrl = 'https://www.google.com/maps/search/' + encodeURIComponent(r.googleMapsQuery);

      var content = '<div style="font-family:Noto Sans JP,sans-serif;min-width:220px;line-height:1.6;padding:4px;">'
        + '<div style="font-size:16px;font-weight:700;color:#1B2D4F;margin-bottom:2px;">' + r.name + '</div>'
        + (r.nameEn ? '<div style="font-size:12px;color:#888;">' + r.nameEn + '</div>' : '')
        + '<div style="margin:8px 0 6px;">'
        + '<span style="display:inline-block;background:' + cc.color + ';color:#fff;padding:2px 10px;border-radius:4px;font-size:11px;font-weight:600;">' + cc.icon + ' ' + cc.label + '</span> '
        + '<span style="font-size:14px;color:#C9A44A;font-weight:700;margin-left:4px;">' + (priceLabels[r.priceRange] || '') + '</span>'
        + '</div>'
        + '<div style="font-size:13px;color:#555;margin-bottom:8px;">📍 ' + r.area + '</div>'
        + '<div style="display:flex;gap:12px;padding-top:8px;border-top:1px solid #eee;">'
        + '<a href="' + gmapsUrl + '" target="_blank" rel="noopener noreferrer" style="font-size:12px;color:#3A6B8C;text-decoration:none;font-weight:600;">Google Map ↗</a>'
        + (r.articleSlug ? '<a href="/articles/' + r.articleSlug + '/" style="font-size:12px;color:#C9A44A;text-decoration:none;font-weight:600;">記事を読む →</a>' : '')
        + '</div></div>';

      marker.addListener('click', function() {
        infoWindow.setContent(content);
        infoWindow.open(map, marker);
      });

      marker._cuisine = r.cuisine;
      allMarkers.push(marker);
      bounds.extend(marker.getPosition());
    });

    if (allMarkers.length > 0) {
      map.fitBounds(bounds, { top: 50, bottom: 50, left: 50, right: 50 });
    }

    // Filter logic
    if (filtersEl) {
      filtersEl.addEventListener('click', function(e) {
        var btn = e.target.closest('.map-filter-btn');
        if (!btn) return;
        filtersEl.querySelectorAll('.map-filter-btn').forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        var cuisine = btn.dataset.cuisine;

        allMarkers.forEach(function(m) {
          if (cuisine === 'all' || m._cuisine === cuisine) {
            m.setVisible(true);
            m.setIcon(Object.assign({}, m.getIcon(), { fillOpacity: 0.9, scale: 12 }));
          } else {
            m.setVisible(false);
          }
        });

        // Re-fit bounds to visible markers
        if (cuisine !== 'all') {
          var newBounds = new google.maps.LatLngBounds();
          var count = 0;
          allMarkers.forEach(function(m) {
            if (m.getVisible()) { newBounds.extend(m.getPosition()); count++; }
          });
          if (count > 0) map.fitBounds(newBounds, { top: 50, bottom: 50, left: 50, right: 50 });
        } else {
          map.fitBounds(bounds, { top: 50, bottom: 50, left: 50, right: 50 });
        }
      });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initWhenVisible);
  } else {
    initWhenVisible();
  }
})();
</script>
