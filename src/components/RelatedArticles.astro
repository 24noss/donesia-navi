---
/**
 * Related Articles component.
 * Shows articles that share tags or category with the current article.
 */
import { getCollection } from 'astro:content';
import { categories, formatDate } from '../lib/categories';
import type { CategorySlug } from '../lib/categories';

interface Props {
  currentId: string;
  category: CategorySlug;
  tags: string[];
  limit?: number;
}

const { currentId, category, tags, limit = 4 } = Astro.props;

const allArticles = await getCollection('articles', ({ data }) => !data.draft);

// Score articles by relevance: shared tags (2 points each) + same category (1 point)
const scored = allArticles
  .filter((a) => a.id !== currentId)
  .map((a) => {
    let score = 0;
    if (a.data.category === category) score += 1;
    for (const tag of a.data.tags) {
      if (tags.includes(tag)) score += 2;
    }
    return { article: a, score };
  })
  .filter((s) => s.score > 0)
  .sort((a, b) => b.score - a.score || b.article.data.pubDate.valueOf() - a.article.data.pubDate.valueOf())
  .slice(0, limit);
---

{scored.length > 0 && (
  <div>
    <div class="section-header">
      <h3 class="section-title">関連記事</h3>
    </div>
    {scored.map(({ article }) => (
      <div class="related-item">
        <span class="related-cat">{categories[article.data.category].name}</span>
        <a class="related-title" href={`/articles/${article.id}/`} style="display:block;">
          {article.data.title}
        </a>
        <div class="related-date">{formatDate(article.data.pubDate)}</div>
      </div>
    ))}
  </div>
)}
