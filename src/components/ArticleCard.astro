---
import { categories, formatDate } from '../lib/categories';
import type { CategorySlug } from '../lib/categories';

interface Props {
  article: {
    id: string;
    data: {
      title: string;
      description: string;
      category: CategorySlug;
      pubDate: Date;
      source?: string;
      tags: string[];
      heroImage?: string;
    };
  };
  featured?: boolean;
}

const { article, featured = false } = Astro.props;
const cat = categories[article.data.category];
const url = `/articles/${article.id}/`;

// Multiple images per category — article ID hash selects unique image
const categoryImagePool: Record<string, string[]> = {
