---
import { categories, formatDate } from '../lib/categories';
import type { CategorySlug } from '../lib/categories';

interface Props {
  article: {
    id: string;
    data: {
      title: string;
      description: string;
      category: CategorySlug;
      pubDate: Date;
      source?: string;
      tags: string[];
      heroImage?: string;
    };
  };
  featured?: boolean;
}

const { article, featured = false } = Astro.props;
const cat = categories[article.data.category];
const url = `/articles/${article.id}/`;

// Category-specific default images from Pexels (Indonesia-themed, free, no attribution)
const categoryImages: Record<string, string> = {
  safety: 'https://images.pexels.com/photos/1739855/pexels-photo-1739855.jpeg?auto=compress&cs=tinysrgb&w=800&h=450&dpr=1',
  society: 'https://images.pexels.com/photos/2166559/pexels-photo-2166559.jpeg?auto=compress&cs=tinysrgb&w=800&h=450&dpr=1',
  business: 'https://images.pexels.com/photos/3184292/pexels-photo-3184292.jpeg?auto=compress&cs=tinysrgb&w=800&h=450&dpr=1',
  lifestyle: 'https://images.pexels.com/photos/2474661/pexels-photo-2474661.jpeg?auto=compress&cs=tinysrgb&w=800&h=450&dpr=1',
  travel: 'https://images.pexels.com/photos/2166553/pexels-photo-2166553.jpeg?auto=compress&cs=tinysrgb&w=800&h=450&dpr=1',
  visa: 'https://images.pexels.com/photos/3769138/pexels-photo-3769138.jpeg?auto=compress&cs=tinysrgb&w=800&h=450&dpr=1',
  regulation: 'https://images.pexels.com/photos/5668858/pexels-photo-5668858.jpeg?auto=compress&cs=tinysrgb&w=800&h=450&dpr=1',
};

const heroImage = article.data.heroImage || categoryImages[article.data.category] || categoryImages.society;

function relativeTime(date: Date): string {
  const now = new Date();
  const diff = now.getTime() - date.getTime();
  const hours = Math.floor(diff / (1000 * 60 * 60));
  const days = Math.floor(diff / (1000 * 60 * 60 * 24));
  if (hours < 1) return '数分前';
  if (hours < 24) return `${hours}時間前`;
  if (days < 7) return `${days}日前`;
  return formatDate(date);
}
---

{featured ? (
  <a href={url} class="featured-hero" style={`background-image:linear-gradient(180deg, rgba(27,45,79,0.05) 0%, rgba(27,45,79,0.6) 40%, rgba(27,45,79,0.95) 100%), url('${heroImage}');background-size:cover;background-position:center;`}>
    <span class="featured-hero-badge">{cat.name}</span>
    <h3 class="featured-hero-title">{article.data.title}</h3>
    <p class="featured-hero-excerpt">{article.data.description}</p>
    <div class="featured-hero-meta">
      {article.data.source && <span class="source">{article.data.source}</span>}
      <span>{relativeTime(article.data.pubDate)}</span>
    </div>
  </a>
) : (
  <a href={url} class="article-card">
    <div class="article-card-image" style={`background-image:url('${heroImage}');`}></div>
    <div class="article-card-body">
      <span class="article-card-badge">{cat.name}</span>
      <h4 class="article-card-title">{article.data.title}</h4>
      <div class="article-card-meta">
        {article.data.source && <span class="source">{article.data.source}</span>}
        <span>{relativeTime(article.data.pubDate)}</span>
      </div>
    </div>
  </a>
)}
