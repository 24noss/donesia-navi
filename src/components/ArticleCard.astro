// Hash article ID to pick a unique image from the pool
function hashCode(str: string): number {
  let hash = 0;
  for (let i = 0; i < str.length; i++) {
    hash = ((hash << 5) - hash) + str.charCodeAt(i);
    hash |= 0;
  }
  return Math.abs(hash);
}

const pool = categoryImagePool[article.data.category] || categoryImagePool.society;
const imageIndex = hashCode(article.id) % pool.length;
const heroImage = article.data.heroImage || pool[imageIndex] + '?auto=compress&cs=tinysrgb&w=800&h=450&dpr=1';

function relativeTime(date: Date): string {
  const now = new Date();
  const diff = now.getTime() - date.getTime();
  const hours = Math.floor(diff / (1000 * 60 * 60));
  const days = Math.floor(diff / (1000 * 60 * 60 * 24));
  if (hours < 1) return '数分前';
  if (hours < 24) return `${hours}時間前`;
  if (days < 7) return `${days}日前`;
  return formatDate(date);
}
---

{featured ? (
  <a href={url} class="featured-hero" style={`background-image:linear-gradient(180deg, rgba(27,45,79,0.05) 0%, rgba(27,45,79,0.6) 40%, rgba(27,45,79,0.95) 100%), url('${heroImage}');background-size:cover;background-position:center;`}>
    <span class="featured-hero-badge">{cat.name}</span>
    <h3 class="featured-hero-title">{article.data.title}</h3>
    <p class="featured-hero-excerpt">{article.data.description}</p>
    <div class="featured-hero-meta">
      {article.data.source && <span class="source">{article.data.source}</span>}
      <span>{relativeTime(article.data.pubDate)}</span>
    </div>
  </a>
) : (
  <a href={url} class="article-card">
    <div class="article-card-image" style={`background-image:url('${heroImage}');`}></div>
    <div class="article-card-body">
      <span class="article-card-badge">{cat.name}</span>
      <h4 class="article-card-title">{article.data.title}</h4>
      <div class="article-card-meta">
        {article.data.source && <span class="source">{article.data.source}</span>}
        <span>{relativeTime(article.data.pubDate)}</span>
      </div>
    </div>
  </a>
)}
