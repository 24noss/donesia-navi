---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import StructuredData from '../../components/StructuredData.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import Sidebar from '../../components/Sidebar.astro';
import { categories } from '../../lib/categories';
import type { CategorySlug } from '../../lib/categories';

export function getStaticPaths() {
  return Object.keys(categories).map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const cat = categories[slug as CategorySlug];
const allArticles = await getCollection('articles', ({ data }) => !data.draft && data.category === slug);
const articles = allArticles.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<Base title={cat.seoTitle} description={cat.description}>
  <StructuredData slot="head" type="category" categorySlug={slug as CategorySlug} />

  <div class="container layout-2col">

    <div class="main-col fade-in">

      <!-- Category Hero -->
      <div class="cat-hero">
        <div class="cat-hero-name">{cat.name}</div>
        <div class="cat-hero-desc">{cat.description}</div>
        <div class="cat-hero-count">{articles.length} 記事</div>
      </div>

      <!-- Filter Bar -->
      <div class="filter-bar">
        <button class="filter-btn active">最新順</button>
        <button class="filter-btn">人気順</button>
      </div>

      {articles.length === 0 ? (
        <p style="color:var(--text-muted);padding:2rem 0;">このカテゴリの記事はまだありません。</p>
      ) : (
        articles.map((article) => (
          <ArticleCard article={article} />
        ))
      )}

    </div>

    <!-- Sidebar -->
    <div class="sidebar-col desktop-only">
      <Sidebar showRate={false} showPopular={true} showCategories={true} showSafety={false} />
    </div>

  </div>

  <!-- Filter button JS -->
  <script is:inline>
    document.querySelectorAll('.filter-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        btn.parentElement.querySelectorAll('.filter-btn').forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
      });
    });
  </script>
</Base>
