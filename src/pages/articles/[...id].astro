---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import StructuredData from '../../components/StructuredData.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import RelatedArticles from '../../components/RelatedArticles.astro';
import Sidebar from '../../components/Sidebar.astro';
import { categories, formatDate } from '../../lib/categories';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => !data.draft);
  return articles.map((article) => ({ params: { id: article.id }, props: { article } }));
}

const { article } = Astro.props;
const { Content } = await render(article);
const cat = categories[article.data.category];
const articleUrl = new URL(`/articles/${article.id}/`, Astro.site).href;

// Get related articles for sidebar
const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const related = allArticles
  .filter((a) => a.id !== article.id)
  .map((a) => {
    let score = 0;
    if (a.data.category === article.data.category) score += 1;
    for (const tag of a.data.tags) {
      if (article.data.tags.includes(tag)) score += 2;
    }
    return { article: a, score };
  })
  .filter((s) => s.score > 0)
  .sort((a, b) => b.score - a.score || b.article.data.pubDate.valueOf() - a.article.data.pubDate.valueOf())
  .slice(0, 4);

const popularArticles = [...allArticles]
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
---
<Base
  title={article.data.title}
  description={article.data.description}
  ogType="article"
  publishedTime={article.data.pubDate.toISOString()}
  modifiedTime={(article.data.updatedDate ?? article.data.pubDate).toISOString()}
  articleSection={cat.name}
  articleTags={article.data.tags}
>
  <StructuredData
    slot="head"
    type="article"
    article={article.data}
    articleUrl={articleUrl}
  />

  <div class="container">

    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="パンくずリスト">
      <a href="/">ホーム</a>
      <span class="sep">›</span>
      <a href={`/category/${article.data.category}/`}>{cat.name}</a>
      <span class="sep">›</span>
      <span>{article.data.title}</span>
    </nav>

    <!-- Article Header -->
    <div class="article-header">
      <span class="article-cat-pill">{cat.name}</span>
      <h1 class="article-page-title">{article.data.title}</h1>
      <div class="article-meta-row">
        <span>著者: DonesiaNavi編集部</span>
        <span class="divider">|</span>
        <span>{formatDate(article.data.pubDate)}</span>
        {article.data.source && (
          <>
            <span class="divider">|</span>
            <span>ソース: {article.data.source}</span>
          </>
        )}
      </div>
      <ShareButtons url={articleUrl} title={article.data.title} direction="horizontal" />
    </div>

    <div class="layout-2col-article">

      <!-- ARTICLE BODY -->
      <div class="main-col">

        <!-- TOC (auto-generated by JS) -->
        <div class="toc" id="toc" style="display:none;">
          <div class="toc-header" id="toc-toggle">
            <span>目次</span>
            <span class="toc-arrow">&#9660;</span>
          </div>
          <div class="toc-body" id="toc-body">
          </div>
        </div>

        {article.data.hasAffiliate && (
          <div class="inline-affiliate">
            <span class="pr-label">PR</span>
            <span>この記事にはアフィリエイト広告が含まれています。<a href="/policy/">詳細</a></span>
          </div>
        )}

        <!-- Body -->
        <div class="article-body" id="article-content">
          <Content />
        </div>

        <!-- Source -->
        {article.data.sourceUrl && (
          <div class="article-source">
            <div class="article-source-title">情報ソース</div>
            <p><a href={article.data.sourceUrl} target="_blank" rel="noopener noreferrer">{article.data.source || '原文'}</a></p>
          </div>
        )}

        <!-- AI Disclosure -->
        <div class="ai-disclosure">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M12 2a4 4 0 014 4v1h1a3 3 0 013 3v8a3 3 0 01-3 3H7a3 3 0 01-3-3v-8a3 3 0 013-3h1V6a4 4 0 014-4z"/><circle cx="9" cy="14" r="1.5"/><circle cx="15" cy="14" r="1.5"/></svg>
          この記事はAIが生成し、人間の編集者がレビューしています。情報の正確性には万全を期していますが、最新情報は公式ソースをご確認ください。
        </div>

        <!-- Bottom share buttons -->
        <div style="margin-top:24px;">
          <ShareButtons url={articleUrl} title={article.data.title} direction="horizontal" />
        </div>

        <!-- Tags -->
        {article.data.tags.length > 0 && (
          <div class="tag-pills">
            {article.data.tags.map((tag: string) => (
              <a class="tag-pill" href={`/tag/${tag}/`}>{tag}</a>
            ))}
          </div>
        )}

        <!-- Related Articles (below content on mobile) -->
        <div style="margin-top:40px;">
          <RelatedArticles
            currentId={article.id}
            category={article.data.category}
            tags={article.data.tags}
          />
        </div>

      </div>

      <!-- ARTICLE SIDEBAR -->
      <div class="sidebar-col desktop-only">
        <div class="sidebar-sticky">

          <!-- Share vertical -->
          <div class="widget">
            <div class="widget-title">この記事を共有</div>
            <ShareButtons url={articleUrl} title={article.data.title} direction="vertical" />
          </div>

          <!-- Affiliate Card -->
          <div class="affiliate-card">
            <span class="pr-badge">PR</span>
            <div class="aff-name">Wise（ワイズ）</div>
            <div class="aff-desc">海外送金の手数料を最大8倍節約。リアルタイム為替レートで日本への送金が簡単・お得に。</div>
            <a href="https://wise.com/invite/dic/shogon67" target="_blank" rel="noopener noreferrer" class="aff-cta">無料アカウント作成 →</a>
          </div>

          <!-- Related Articles -->
          {related.length > 0 && (
            <div class="widget">
              <div class="widget-title">関連記事</div>
              {related.map(({ article: rel }) => (
                <div class="related-item">
                  <span class="related-cat">{categories[rel.data.category].name}</span>
                  <a class="related-title" href={`/articles/${rel.id}/`}>{rel.data.title}</a>
                  <div class="related-date">{formatDate(rel.data.pubDate)}</div>
                </div>
              ))}
            </div>
          )}

          <!-- Popular -->
          <div class="widget">
            <div class="widget-title"><span class="icon">&#128293;</span> 人気記事</div>
            <div class="popular-list">
              {popularArticles.map((a, i) => (
                <div class="popular-item">
                  <span class="popular-num">{i + 1}</span>
                  <a class="popular-title" href={`/articles/${a.id}/`}>{a.data.title}</a>
                </div>
              ))}
            </div>
          </div>

          <!-- Rate mini -->
          <div class="widget">
            <div class="widget-title"><span class="icon">&#9733;</span> 為替レート</div>
            <div class="rate-big" style="font-size:24px">--</div>
            <div class="rate-pair">1 JPY = IDR</div>
            <a href="https://wise.com/invite/dic/shogon67" target="_blank" rel="noopener noreferrer" class="wise-link">Wise で送金 →<span class="pr">PR</span></a>
          </div>

        </div>
      </div>

    </div>

    <!-- Mobile share bar -->
    <div class="mobile-share-bar">
      <ShareButtons url={articleUrl} title={article.data.title} direction="horizontal" />
    </div>

  </div>

  <!-- TOC auto-generation script -->
  <script is:inline>
    (function(){
      var content = document.getElementById('article-content');
      var tocEl = document.getElementById('toc');
      var tocBody = document.getElementById('toc-body');
      var tocToggle = document.getElementById('toc-toggle');
      if (!content || !tocEl || !tocBody) return;

      var headings = content.querySelectorAll('h2');
      if (headings.length === 0) return;

      tocEl.style.display = 'block';

      headings.forEach(function(h, i) {
        var id = h.id || ('section-' + (i + 1));
        h.id = id;
        var link = document.createElement('a');
        link.className = 'toc-link';
        link.href = '#' + id;
        link.textContent = h.textContent;
        tocBody.appendChild(link);
      });

      if (tocToggle) {
        tocToggle.addEventListener('click', function() {
          tocEl.classList.toggle('collapsed');
        });
      }
    })();
  </script>
</Base>
