---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ArticleCard from '../../components/ArticleCard.astro';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => !data.draft);
  const allTags = new Set<string>();
  articles.forEach(a => a.data.tags.forEach(t => allTags.add(t)));
  return [...allTags].map(tag => ({
    params: { tag },
    props: { tag },
  }));
}

const { tag } = Astro.props;
const allArticles = await getCollection('articles', ({ data }) => !data.draft && data.tags.includes(tag));
const articles = allArticles.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<Base title={`#${tag} の記事一覧`} description={`「${tag}」タグが付いた記事の一覧です。`}>

  <div class="container static-page">

    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="パンくずリスト">
      <a href="/">ホーム</a>
      <span class="sep">></span>
      <span>タグ</span>
      <span class="sep">></span>
      <span>#{tag}</span>
    </nav>

    <h1>#{tag}</h1>
    <p style="font-size:13px;color:var(--text-muted);margin-bottom:24px;">
      「{tag}」タグが付いた記事 ({articles.length}件)
    </p>

    {articles.length === 0 ? (
      <p style="color:var(--text-muted);padding:2rem 0;">このタグの記事はまだありません。</p>
    ) : (
      articles.map((article) => (
        <ArticleCard article={article} />
      ))
    )}

    <div style="margin-top:2rem;">
      <a href="/" style="color:var(--teal);">&larr; トップに戻る</a>
    </div>

  </div>
</Base>
