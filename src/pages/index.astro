---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import StructuredData from '../components/StructuredData.astro';
import ArticleCard from '../components/ArticleCard.astro';
import Sidebar from '../components/Sidebar.astro';
import ExchangeRate from '../components/ExchangeRate.astro';
import { formatDate } from '../lib/categories';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const articles = allArticles.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featured = articles[0];
const rest = articles.slice(1);

const todayStr = formatDate(new Date());
---
<Base title="DonesiaNavi（ドネシアナビ） | インドネシア在住日本人向けニュース・生活情報" description="インドネシア在住日本人のための日本語ニュース・生活情報ポータル。安全情報、ビザ、経済、生活、旅行などの最新ニュースを毎日お届け。">
  <StructuredData slot="head" type="home" />

  <!-- FULL-WIDTH HERO (G3 style - outside 2-column layout) -->
  {featured && (
    <div class="container" style="padding-top:24px;">
      <ArticleCard article={featured} featured={true} />
    </div>
  )}

  <div class="container layout-2col">

    <!-- MAIN COLUMN -->
    <div class="main-col fade-in">

      <!-- Daily Digest Banner -->
      <div class="digest-banner">
        <div>
          <div class="digest-date"><strong>今日のインドネシア</strong>{todayStr}</div>
        </div>
        <div class="digest-rate">
          <ExchangeRate variant="banner" />
        </div>
        <div class="digest-weather" id="weather-display">ジャカルタ --°C<br><span style="font-size:11px;opacity:.6">天気情報取得中</span></div>
      </div>

      {articles.length === 0 ? (
        <p style="color:var(--text-muted);padding:2rem 0;">記事の準備中です。</p>
      ) : (
        <>
          <!-- Latest Articles (G4 card grid) -->
          <div class="section-header">
            <h2 class="section-title">最新ニュース</h2>
          </div>

          <div class="article-grid">
            {rest.map((article) => (
              <ArticleCard article={article} />
            ))}
          </div>
        </>
      )}

    </div>

    <!-- SIDEBAR -->
    <div class="sidebar-col desktop-only">
      <Sidebar showRate={false} showPopular={true} showCategories={true} showSafety={true} />
    </div>

  </div>
  <script is:inline>
    (function(){
      var KEY = 'dn_weather';
      var TTL = 30 * 60 * 1000; // 30 min cache
      var el = document.getElementById('weather-display');
      if (!el) return;

      var cached = localStorage.getItem(KEY);
      if (cached) {
        try {
          var d = JSON.parse(cached);
          if (Date.now() - d.ts < TTL) { el.innerHTML = d.html; return; }
        } catch(e) {}
      }

      fetch('https://api.open-meteo.com/v1/forecast?latitude=-6.2088&longitude=106.8456&current=temperature_2m,weathercode&timezone=Asia/Jakarta')
        .then(r => r.json())
        .then(data => {
          var temp = Math.round(data.current.temperature_2m);
          var code = data.current.weathercode;
          var desc = code <= 3 ? '晴れ' : code <= 48 ? '曇り' : code <= 67 ? '雨' : code <= 77 ? '雪' : '雷雨';
          var icon = code <= 3 ? '☀️' : code <= 48 ? '☁️' : code <= 67 ? '🌧️' : '⛈️';
          var html = icon + ' ジャカルタ ' + temp + '°C<br><span style="font-size:11px;opacity:.6">' + desc + '</span>';
          el.innerHTML = html;
          localStorage.setItem(KEY, JSON.stringify({html: html, ts: Date.now()}));
        })
        .catch(function(){ el.innerHTML = 'ジャカルタ --°C'; });
    })();
  </script>
</Base>
