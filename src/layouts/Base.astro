---
import '../styles/global.css';
import { categories } from '../lib/categories';

interface Props {
  title: string;
  description?: string;
  ogType?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  articleSection?: string;
  articleTags?: string[];
  noindex?: boolean;
}

const {
  title,
  description = 'インドネシア在住日本人のための日本語ニュース・生活情報ポータル',
  ogType = 'website',
  publishedTime,
  modifiedTime,
  articleSection,
  articleTags = [],
  noindex = false,
} = Astro.props;

const isHome = title.startsWith('DonesiaNavi');
const fullTitle = isHome ? title : `${title} | DonesiaNavi（ドネシアナビ）`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const siteUrl = Astro.site?.href ?? 'https://indonesia-navi.com';
const ogImageUrl = `${siteUrl}og-default.png`;

const currentPath = Astro.url.pathname;
---
<!doctype html>
<html lang="ja" data-theme="light">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="agd-partner-manual-verification" />
  <link rel="icon" type="image/png" href="/favicon.png" />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@400;500;600;700;900&family=Noto+Sans+JP:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />

  <!-- Google Analytics (GA4) -->
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-14DJYTRJTR"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-14DJYTRJTR');
  </script>

  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}
  <title>{fullTitle}</title>

  <!-- Canonical & hreflang -->
  <link rel="canonical" href={canonicalUrl} />
  <link rel="alternate" hreflang="ja" href={canonicalUrl} />
  <link rel="alternate" hreflang="x-default" href={canonicalUrl} />

  <!-- Sitemap -->
  <link rel="sitemap" href="/sitemap-index.xml" />

  <!-- RSS Feed -->
  <link rel="alternate" type="application/rss+xml" title="DonesiaNavi" href={`${siteUrl}rss.xml`} />

  <!-- Open Graph -->
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:locale" content="ja_JP" />
  <meta property="og:site_name" content="DonesiaNavi" />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={fullTitle} />

  {ogType === 'article' && publishedTime && (
    <meta property="article:published_time" content={publishedTime} />
  )}
  {ogType === 'article' && modifiedTime && (
    <meta property="article:modified_time" content={modifiedTime} />
  )}
  {ogType === 'article' && articleSection && (
    <meta property="article:section" content={articleSection} />
  )}
  {ogType === 'article' && articleTags.map((tag) => (
    <meta property="article:tag" content={tag} />
  ))}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />

  <!-- Dark mode: restore preference before paint -->
  <script is:inline>
    (function(){
      var t = localStorage.getItem('theme');
      if (t === 'dark') document.documentElement.setAttribute('data-theme','dark');
    })();
  </script>

  <!-- Structured data slot (injected by pages) -->
  <slot name="head" />
</head>
<body>

  <!-- HEADER -->
  <header class="header">
    <div class="header-inner">
      <a href="/" class="logo">
        <span class="logo-donesia">DONESIA</span><span class="logo-navi">NAV<span class="dot">i</span></span>
      </a>
      <div class="header-actions">
        <a href="/search/" class="header-btn" aria-label="検索" title="検索">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        </a>
        <button class="header-btn" id="theme-toggle" aria-label="ダークモード切替" title="ダークモード">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79z"/></svg>
        </button>
      </div>
    </div>
  </header>

  <!-- SUB NAV -->
  <nav class="subnav">
    <div class="subnav-inner">
      <a href="/" class={`subnav-link${currentPath === '/' ? ' active' : ''}`}>トップ</a>
      {Object.entries(categories).map(([slug, cat]) => (
        <a href={`/category/${slug}/`} class={`subnav-link${currentPath.startsWith(`/category/${slug}`) ? ' active' : ''}`}>{cat.name}</a>
      ))}
      <a href="/about/" class={`subnav-link${currentPath.startsWith('/about') ? ' active' : ''}`}>このサイトについて</a>
    </div>
  </nav>

  <!-- MAIN CONTENT -->
  <main>
    <slot />
  </main>

  <!-- FOOTER -->
  <footer class="site-footer">
    <div class="container">
      <p>&copy; {new Date().getFullYear()} DonesiaNavi. この記事はAIが生成し、人間の編集者がレビューしています。</p>
      <div class="footer-links">
        <a href="/about/">このサイトについて</a>
        <a href="/policy/">ポリシー</a>
        {Object.entries(categories).map(([slug, cat]) => (
          <a href={`/category/${slug}/`}>{cat.name}</a>
        ))}
      </div>
    </div>
  </footer>

  <!-- MOBILE BOTTOM NAV -->
  <nav class="mobile-nav">
    <div class="mobile-nav-inner">
      <a href="/" class={`mobile-nav-item${currentPath === '/' ? ' active' : ''}`}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12l9-9 9 9"/><path d="M5 10v10a1 1 0 001 1h3a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1h3a1 1 0 001-1V10"/></svg>
        <span>ホーム</span>
      </a>
      <button class={`mobile-nav-item${currentPath.startsWith('/category') ? ' active' : ''}`} id="category-nav-btn" aria-label="カテゴリを開く">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
        <span>カテゴリ</span>
      </button>
      <a href="/search/" class={`mobile-nav-item${currentPath.startsWith('/search') ? ' active' : ''}`}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <span>検索</span>
      </a>
      <button class="mobile-nav-item" id="fx-nav-btn" aria-label="為替レートを表示">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1v22M17 5H9.5a3.5 3.5 0 100 7h5a3.5 3.5 0 110 7H6"/></svg>
        <span>為替</span>
      </button>
      <a href="/about/" class={`mobile-nav-item${currentPath.startsWith('/about') ? ' active' : ''}`}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        <span>マイページ</span>
      </a>
    </div>
  </nav>

  <!-- CATEGORY OVERLAY -->
  <div class="category-overlay" id="category-overlay">
    <div class="category-overlay-header">
      <h2 class="category-overlay-title">カテゴリ</h2>
      <button class="category-overlay-close" id="category-overlay-close" aria-label="閉じる">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
    </div>
    <div class="category-overlay-list">
      {Object.entries(categories).map(([slug, cat]) => (
        <a href={`/category/${slug}/`} class="category-overlay-item">
          <span class={`cat-dot ${slug}`}></span>
          <span class="category-overlay-name">{cat.name}</span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
        </a>
      ))}
    </div>
  </div>

  <!-- Dark mode toggle JS + Mobile nav JS -->
  <script is:inline>
    (function(){
      // Dark mode toggle
      var toggle = document.getElementById('theme-toggle');
      if (toggle) {
        toggle.addEventListener('click', function(){
          var html = document.documentElement;
          var current = html.getAttribute('data-theme');
          var next = current === 'dark' ? 'light' : 'dark';
          html.setAttribute('data-theme', next);
          localStorage.setItem('theme', next);
        });
      }

      // Category overlay
      var catBtn = document.getElementById('category-nav-btn');
      var catOverlay = document.getElementById('category-overlay');
      var catClose = document.getElementById('category-overlay-close');
      if (catBtn && catOverlay && catClose) {
        catBtn.addEventListener('click', function(){
          catOverlay.classList.add('open');
          document.body.style.overflow = 'hidden';
        });
        catClose.addEventListener('click', function(){
          catOverlay.classList.remove('open');
          document.body.style.overflow = '';
        });
        catOverlay.addEventListener('click', function(e){
          if (e.target === catOverlay) {
            catOverlay.classList.remove('open');
            document.body.style.overflow = '';
          }
        });
      }

      // Exchange rate scroll/navigate
      var fxBtn = document.getElementById('fx-nav-btn');
      if (fxBtn) {
        fxBtn.addEventListener('click', function(){
          var banner = document.querySelector('.digest-banner');
          if (banner) {
            banner.scrollIntoView({ behavior: 'smooth', block: 'center' });
          } else {
            window.location.href = '/#exchange-rate';
          }
        });
      }
    })();
  </script>

</body>
</html>
